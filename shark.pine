//@version=6
library("shark")

var int lookback = input.int(100, title = "Lookback")

if barstate.islast
	var int idx = 0
	for var int i = 0 to lookback - 2
		var int snd = i + 1
		var int thrd = i + 2

		if open[thrd] < open[snd] and close[thrd] > close[snd] and open[snd] < open[i] and close[snd] > close[i]
			label.new(bar_index - thrd, high[thrd], 'Shark')
