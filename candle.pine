//@version=6
library("candle")

import JackisaDayTrader/err/1
import JackisaDayTrader/util/1

export type Label
	int idx
	string str

export doji(int lookback) =>
	if lookback < 0
		err.print("Index not natural number")

		na

	var int offset = na
	for var int i = 0 to lookback
		if close[i] == open[i]
			offset := i	

			break

	if offset != na
		label.new(bar_index[offset], high[offset], "Doji Candle")

export inside(int lookback) =>
	if lookback < 0
		err.print("Index not natural number")

		na

	if lookback < 2
		err.print("Index too small to accomodate size of pattern")

		na

	var int offset = na
	for var int i = 0 to lookback
		int idx_fst = i + 1

		if util.body_floor(i) > util.body_floor(idx_fst) and util.body_roof(i) < util.body_roof(idx_fst)
			offset := i

			break

	if offset != na
		label.new(bar_index[offset], high[offset], "Inside Bar")

export bull(int lookback) =>
	if lookback < 0
		err.print("Index not natural number")

		na

	var int offset = na
	for var int i = 0 to lookback
		if close[i] > open[i]
			offset := i

			break

	if offset != na
		label.new(bar_index[offset], high[offset], "Bullish Candle")

export bear(int lookback) =>
	if lookback < 0
		err.print("Index not natural number")

		na

	var int offset = na
	for var int i = 0 to lookback
		if close[i] > open[i]
			offset := i

			break

	if offset != na
		label.new(bar_index[offset], high[offset], "Bearish Candle")
