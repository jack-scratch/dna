//@version=6
indicator("High Wave Candle", overlay = true)

var int lookback = input.int(100, title = "Lookback")

if barstate.islast
	var int idx = 0
	for var int i = 0 to lookback
		if high[i] - low[i] >= (close[i] - open[i]) * 2
			idx := i	

			break

	label.new(bar_index - idx, high[idx], "High Wave Candle")
