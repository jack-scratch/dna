//@version=6
library("bar")

import JackisaDayTrader/err/1
import JackisaDayTrader/util/1

export type Rng
	float high
	float low

export type Bar
	Rng body
	Rng wick

export type Tag
	int idx
	string s

export bull(int offset) =>
	if offset < 0
		err.print(err.Err.idx_neg)

		na

	if offset < 1
		err.print(err.Err.idx_small)

		na

	close[offset] > open[offset]

export bear(int offset) =>
	if offset < 0
		err.print(err.Err.idx_neg)

		na

	if offset < 1
		err.print(err.Err.idx_small)

		na

	close[offset] < open[offset]

export inside(int offset) =>
	if offset < 0
		err.print(err.Err.idx_neg)

		na

	if offset < 2
		err.print(err.Err.idx_small)

		na

	var float idx_fst = offset + 1
	util.body_floor(offset) > util.body_floor(idx_fst) and util.body_roof(offset) < util.body_roof(idx_fst)

export doji(int offset) =>
	if offset < 0
		err.print(err.Err.idx_neg)

		na

	if offset < 1
		err.print(err.Err.idx_small)

		na

	open[offset] == close[offset]

export doji_gravestone(int offset) =>
	if offset < 0
		err.print(err.Err.idx_neg)

		na

	if offset < 1
		err.print(err.Err.idx_small)

		na

	float o = open[offset]
	doji(offset) and low[offset] == o and high[offset] != o

export doji_one_legged(int offset) =>
	if offset < 0
		err.print(err.Err.idx_neg)

		na

	if offset < 1
		err.print(err.Err.idx_small)

		na

	float mid = open[offset]
	close[offset] == mid and (low[offset] != mid or high[offset] != mid)
	
export hammer_inverted(int offset) =>
	if offset < 0
		err.print(err.Err.idx_neg)

		na

	if offset < 1
		err.print(err.Err.idx_small)

		na

	float offset_o = open[offset]
	float offset_c = close[offset]
	high[offset] - math.max(offset_o, offset_c) > math.abs(offset_o - offset_c)

export high_wave(int offset) =>
	if offset < 0
		err.print(err.Err.idx_neg)

		na

	if offset < 1
		err.print(err.Err.idx_small)

		na

	high[offset] - low[offset] >= (close[offset] - open[offset]) * 2

export pinbar(int offset) =>
	if offset < 0
		err.print(err.Err.idx_neg)

		na

	if offset < 1
		err.print(err.Err.idx_small)

		na

	math.abs(high[offset] - low[offset]) >= math.abs(close[offset] - open[offset]) * (2 / 3)
