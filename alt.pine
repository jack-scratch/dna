//@version=6
library("alt")

export type Alt
	string name
	string[] alt

export alt_print(Alt alt) =>
	str.format('{0} ({1})', alt.name, array.join(alt.alt, ", "))

string[] l_alt = array.new<string>()
l_alt.push('L')
Alt l = Alt.new('Low', l_alt)

string[] h_alt = array.new<string>()
h_alt.push('H')
Alt h = Alt.new('High', h_alt)
