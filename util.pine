//@version=6
library("util")

export body_floor(int idx) =>
	math.min(open[idx], close[idx])

export body_roof(int idx) =>
	math.max(open[idx], close[idx])

export body(int idx) =>
	[body_floor(idx), body_roof(idx)]

export wick_upper(int idx)
	math.abs(high - body_roof(idx))

export wick_lower(int idx)
	math.abs(low - body_floor(idx))
