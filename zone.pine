//@version=6
library("zone")

import JackisaDayTrader/err/1

export type Zone
	int start
	int end
	float floor
	float roof

export gap_up(int lookback) =>
	if lookback < 0
		err.print_enum(err.Err.idx_neg)

		na

	if lookback < 2
		err.print_enum(err.Err.idx_small)

		na

	close[lookback] < open[lookback - 1]

export gap_down(int lookback) =>
	if lookback < 0
		err.print_enum(err.Err.idx_neg)

		na

	if lookback < 2
		err.print_enum(err.Err.idx_small)

		na

	close[lookback] > open[lookback - 1]
