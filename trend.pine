//@version=6
library("trend")

export up(int lookback) =>
	if low <= low[lookback]
  	na

	for var int i = 1 to lookback
		if low <= low[i]
			na

	line.new(bar_index, low, bar_index[lookback], low[lookback])

	const string name = "Uptrend"

	label.new(bar_index, low, name)
	label.new(bar_index[lookback], low[lookback], name)

export down(int lookback) =>
	if high >= high[lookback]
		na

	for var int i = 1 to lookback
		if high >= high[i]
			na

	line.new(bar_index, high, bar_index[lookback], high[lookback])

	const string name = "Downtrend"

	label.new(bar_index, high, name)
	label.new(bar_index[lookback], high[lookback], name)
