//@version=6
library("trend")

import JackisaDayTrader/err/1

export type Seg
	int l
	int l_lvl
	int r
	int r_lvl
	string str

export up(int lookback) =>
	if lookback < 0
		err.print(err.Err.idx_neg)

		na

	if lookback < 1
		err.print(err.Err.idx_small)

		na

	if low <= low[lookback]
  	na

	for var int i = 1 to lookback
		if low <= low[i]
			na

	Seg.new(bar_index, low, bar_index[lookback], low[lookback], "Uptrend")

export down(int lookback) =>
	if lookback < 0
		err.print(err.Err.idx_neg)

		na

	if lookback < 1
		err.print(err.Err.idx_small)

		na

	if high >= high[lookback]
		na

	for var int i = 1 to lookback
		if high >= high[i]
			na

	Seg.new(bar_index, high, bar_index[lookback], high[lookback], "Downtrend")
